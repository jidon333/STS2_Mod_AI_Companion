<Window x:Class="Sts2AiCompanion.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="STS2 AI Companion" Height="860" Width="1500" MinHeight="760" MinWidth="1280">
    <Grid Background="#F5F1E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="18" Padding="18" CornerRadius="14" Background="#143642">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="#F4F1DE" Text="STS2 AI Companion" />
                    <TextBlock Margin="0,6,0,0" Foreground="#D7E3D4" Text="{Binding StatusLine}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Foreground="#F4F1DE" Text="{Binding RunLine}" />
                    <TextBlock Foreground="#F4F1DE" Text="{Binding ScreenLine}" />
                    <TextBlock Foreground="#D7E3D4" Text="{Binding UpdatedLine}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0" Padding="16" CornerRadius="14" Background="#FFFDF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#143642" Text="Current State" />
                    <TextBlock Grid.Row="1" Margin="0,14,0,0" TextWrapping="Wrap" Text="{Binding PlayerLine}" />
                    <TextBlock Grid.Row="2" Margin="0,12,0,0" FontWeight="SemiBold" Text="Deck Summary" />
                    <TextBlock Grid.Row="3" TextWrapping="Wrap" Text="{Binding DeckLine}" />
                    <TextBlock Grid.Row="4" Margin="0,12,0,0" FontWeight="SemiBold" Text="Relics / Potions" />
                    <TextBlock Grid.Row="5" TextWrapping="Wrap" Text="{Binding RelicsPotionsLine}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="0,0,12,0" Padding="16" CornerRadius="14" Background="#FFFDF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#143642" Text="AI Advice" />
                    <TextBlock Grid.Row="1" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Text="{Binding AdviceHeadline}" />
                    <TextBlock Grid.Row="2" Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding AdviceSummary}" />
                    <TextBlock Grid.Row="3" Margin="0,12,0,0" FontWeight="SemiBold" Text="{Binding RecommendedActionLine}" />
                    <TextBlock Grid.Row="4" Margin="0,4,0,0" Text="{Binding RecommendedChoiceLine}" />
                    <GroupBox Grid.Row="5" Margin="0,16,0,0" Header="Reasons / Risks / Recent Changes">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0" ItemsSource="{Binding ReasoningBullets}" />
                            <ListBox Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding RiskNotes}" />
                            <ListBox Grid.Row="2" Margin="0,8,0,0" ItemsSource="{Binding RecentChanges}" />
                        </Grid>
                    </GroupBox>
                    <TextBlock Grid.Row="6" Margin="0,12,0,0" HorizontalAlignment="Right" Text="{Binding ConfidenceLine}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16" CornerRadius="14" Background="#FFFDF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#143642" Text="Choices / Events / Knowledge" />
                    <GroupBox Grid.Row="1" Margin="0,14,0,0" Header="Current Choices">
                        <ListBox ItemsSource="{Binding CurrentChoices}" />
                    </GroupBox>
                    <GroupBox Grid.Row="2" Margin="0,12,0,0" Header="Recent Events">
                        <ListBox ItemsSource="{Binding RecentEvents}" />
                    </GroupBox>
                    <GroupBox Grid.Row="3" Margin="0,12,0,0" Header="Knowledge Slice">
                        <ListBox ItemsSource="{Binding KnowledgeEntries}" />
                    </GroupBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="18,0,18,18" Padding="14" CornerRadius="14" Background="#143642">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button Width="140" Height="40" Margin="0,0,8,0" Content="Analyze Now" Click="AnalyzeNow_OnClick" />
                <Button Width="160" Height="40" Margin="0,0,8,0" Content="{Binding AutoAdviceButtonText}" Click="ToggleAutoAdvice_OnClick" />
                <Button Width="120" Height="40" Margin="0,0,8,0" Content="Retry Last" Click="RetryLast_OnClick" />
                <Button Width="150" Height="40" Margin="0,0,8,0" Content="Refresh Knowledge" Click="RefreshKnowledge_OnClick" />
                <Button Width="130" Height="40" Content="Open Artifacts" Click="OpenArtifacts_OnClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
