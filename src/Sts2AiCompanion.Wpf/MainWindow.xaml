<Window x:Class="Sts2AiCompanion.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="STS2 AI 어시스턴트"
        Height="860"
        Width="1500"
        MinHeight="760"
        MinWidth="1280">
    <Window.Resources>
        <Style x:Key="ReadOnlyPanelTextBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="ScrollablePanelTextBox" TargetType="TextBox" BasedOn="{StaticResource ReadOnlyPanelTextBox}">
            <Setter Property="MinHeight" Value="180" />
            <Setter Property="MaxHeight" Value="320" />
            <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
        </Style>
    </Window.Resources>

    <Grid Background="#F5F1E8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="18" Padding="18" CornerRadius="14" Background="#143642">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="#F4F1DE" Text="STS2 AI 어시스턴트" />
                    <TextBlock Margin="0,6,0,0" Foreground="#D7E3D4" Text="{Binding StatusLine}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Foreground="#F4F1DE" Text="{Binding RunLine}" />
                    <TextBlock Foreground="#F4F1DE" Text="{Binding ScreenLine}" />
                    <TextBlock Foreground="#D7E3D4" Text="{Binding UpdatedLine}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0" Padding="16" CornerRadius="14" Background="#FFFDF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#143642" Text="현재 상태" />
                    <TextBox Grid.Row="1" Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding PlayerText, Mode=OneWay}" />
                    <TextBlock Grid.Row="2" Margin="0,10,0,0" FontWeight="SemiBold" Text="덱 요약" />
                    <TextBox Grid.Row="3" Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding DeckText, Mode=OneWay}" />
                    <TextBlock Grid.Row="4" Margin="0,10,0,0" FontWeight="SemiBold" Text="유물 / 포션" />
                    <TextBox Grid.Row="5" Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding RelicsPotionsText, Mode=OneWay}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="0,0,12,0" Padding="16" CornerRadius="14" Background="#FFFDF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#143642" Text="AI 조언" />
                    <TextBlock Grid.Row="1" Margin="0,10,0,0" FontWeight="SemiBold" Foreground="#7A3E00" Text="{Binding AnalysisStatusText}" />
                    <ScrollViewer Grid.Row="2" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <GroupBox Header="최종 조언">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding AdviceOverviewText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="최종 근거 / 리스크 / 부족한 정보 / 최근 변화">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding AdviceDetailsText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="보수적 조언">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding ConservativeAdviceText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="공격적 조언">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding AggressiveAdviceText, Mode=OneWay}" />
                            </GroupBox>

                            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Right" Text="{Binding ConfidenceLine}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16" CornerRadius="14" Background="#FFFDF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#143642" Text="현재 scene model" />

                    <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <GroupBox Header="sceneType / stage / owner">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding SceneIdentityText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="요약">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding SceneSummaryText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="현재 장면 맥락">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding SceneContextText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="보이는 선택지">
                                <TextBox Style="{StaticResource ScrollablePanelTextBox}" Text="{Binding SceneOptionsText, Mode=OneWay}" />
                            </GroupBox>

                            <GroupBox Margin="0,12,0,0" Header="누락 정보 / observer gaps">
                                <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding SceneGapsText, Mode=OneWay}" />
                            </GroupBox>

                            <Expander Margin="0,12,0,0" Header="고급 정보" IsExpanded="False">
                                <StackPanel Margin="0,12,0,0">
                                    <GroupBox Header="AI 입력 해석">
                                        <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding AiPromptSummaryText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Header="AI 입력">
                                        <TextBox Style="{StaticResource ScrollablePanelTextBox}" Text="{Binding AiInputText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Margin="0,12,0,0" Header="AI 프롬프트 미리보기">
                                        <TextBox Style="{StaticResource ScrollablePanelTextBox}" Text="{Binding AiPromptPreviewText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Margin="0,12,0,0" Header="현재 장면 진단">
                                        <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding CurrentSceneDiagnosticsText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Header="confidence / source refs">
                                        <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding SceneProvenanceText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Margin="0,12,0,0" Header="최근 이벤트">
                                        <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding RecentEventsText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Margin="0,12,0,0" Header="관련 지식">
                                        <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding KnowledgeEntriesText, Mode=OneWay}" />
                                    </GroupBox>

                                    <GroupBox Margin="0,12,0,0" Header="수집 런 진단">
                                        <TextBox Style="{StaticResource ReadOnlyPanelTextBox}" Text="{Binding CollectorNotesText, Mode=OneWay}" />
                                    </GroupBox>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="18,0,18,18" Padding="14" CornerRadius="14" Background="#143642">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#F4F1DE" Text="모델" />
                    <ComboBox Width="190"
                              ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModelOption, Mode=OneWay}"
                              SelectionChanged="ModelSelection_OnChanged" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#F4F1DE" Text="추론" />
                    <ComboBox Width="160"
                              ItemsSource="{Binding AvailableReasoningOptions}"
                              SelectedItem="{Binding SelectedReasoningOption, Mode=OneWay}"
                              SelectionChanged="ReasoningSelection_OnChanged" />
                </StackPanel>
                <Button Width="140" Height="40" Margin="0,0,8,0" Content="지금 분석" Click="AnalyzeNow_OnClick" />
                <Button Width="160" Height="40" Margin="0,0,8,0" Content="{Binding AutoAdviceButtonText}" Click="ToggleAutoAdvice_OnClick" />
                <Button Width="120" Height="40" Margin="0,0,8,0" Content="다시 시도" Click="RetryLast_OnClick" />
                <Button Width="150" Height="40" Margin="0,0,8,0" Content="지식 새로고침" Click="RefreshKnowledge_OnClick" />
                <Button Width="130" Height="40" Content="산출물 열기" Click="OpenArtifacts_OnClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
