{
  "id": "smoke.ironclad.first-reward",
  "description": "Start a standard Ironclad run, clear the first combat, take the first reward, and return to the map.",
  "steps": [
    {
      "name": "main-menu",
      "targetScene": "main-menu",
      "actionKind": "click_button",
      "targetLabel": "__start__",
      "expectedResult": "singleplayer-submenu"
    },
    {
      "name": "open-standard-run",
      "targetScene": "singleplayer-submenu",
      "actionKind": "click_button",
      "targetLabel": "__standard_run__",
      "expectedResult": "character-select"
    },
    {
      "name": "choose-ironclad",
      "targetScene": "character-select",
      "actionKind": "click_button",
      "targetLabel": "__ironclad__",
      "expectedResult": "character-select"
    },
    {
      "name": "confirm-run-start",
      "targetScene": "character-select",
      "actionKind": "click_button",
      "targetLabel": "__confirm__",
      "expectedResult": "map"
    },
    {
      "name": "first-map-node",
      "targetScene": "map",
      "actionKind": "choose_map_node",
      "targetLabel": "__first_combat__",
      "expectedResult": "combat"
    },
    {
      "name": "combat-loop",
      "targetScene": "combat",
      "actionKind": "combat-basic",
      "targetLabel": "__first_playable__",
      "expectedResult": "reward"
    },
    {
      "name": "pick-first-reward",
      "targetScene": "reward",
      "actionKind": "choose_reward",
      "targetLabel": "__first_reward__",
      "expectedResult": "map"
    }
  ]
}
